# ── LLM ───────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ── Search ────────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
SERPAPI_KEY=your_serpapi_key_here          # fallback web search

# ── Data sources ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
GITHUB_TOKEN=your_github_personal_access_token_here   # for gitingest / raw repo access

# ── Optional ──────────────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here  # unauthenticated works too
FIRECRAWL_API_KEY=your_firecrawl_api_key_here            # enhanced web crawling

# ── Auto-detected by scripts/debug_gemini.py ──────────────────────────────────
GEMINI_MODEL=                  # leave blank — debug_gemini.py fills this in automatically
